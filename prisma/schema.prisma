// Prisma 7+ schema — connection URL is configured in prisma.config.ts

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// NextAuth.js v5 required models
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // bcrypt hash — null for OAuth users
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Subscription tier: seedling | grower | harvest
  plan                   String    @default("seedling")
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Gardening preferences (all optional)
  zipCode     String?
  usdaZone    String?
  soilType    String?
  experience  String?
  waterPref   String?
  sunExposure String?
  orientation String?
  goals       String[]

  accounts Account[]
  sessions Session[]
  gardens  Garden[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────
// Garden Planner models
// ─────────────────────────────────────────────

model Garden {
  id           String   @id @default(cuid())
  userId       String
  name         String
  slug         String
  widthFt      Float
  lengthFt     Float
  usdaZone     String
  soilType     String
  sunExposure  String
  orientation  String
  style        String
  experience   String
  goals        String[]
  waterPref    String
  wantedPlants String[]
  designJson   Json
  svgSnapshot  String?  @db.Text
  isPublic     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plants GardenPlant[]

  @@unique([userId, slug])
  @@index([userId])
}

model GardenPlant {
  id        String  @id @default(cuid())
  gardenId  String
  plantId   String
  plantName String
  emoji     String
  gridX     Int
  gridY     Int
  zoneColor String?

  garden Garden @relation(fields: [gardenId], references: [id], onDelete: Cascade)

  @@index([gardenId])
}
